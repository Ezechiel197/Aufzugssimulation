  state {
    id			    96
    labelString		    "eML_blk_kernel()"
    position		    [18 64.5 118 66]
    fontSize		    12
    chart		    95
    treeNode		    [95 0 0 0]
    superState		    SUBCHART
    subviewer		    95
    ssIdNumber		    1
    type		    FUNC_STATE
    decomposition	    CLUSTER_STATE
    eml {
      isEML		      1
      script		      "function y = fcn(xSoll,Tuerstatus,Anforderung,Simulationszeit,xIst)\n%Funktion zum Uebergeben der"
      " Simulationszeit und X-Sollwert an MATLAB\n\neml.extrinsic('assignin')                                          "
      "         %Laedt die Funktion 'assignin' aus der Bibliothek  \nassignin('base','tsim',Simulationszeit);          "
      "                          %Schreibt die aktuelle Simulationszeit in 'tsim'\nassignin('base','GUI_Tuer',Tuerstatu"
      "s);                                  %Schreibt den Status der Tuer in 'Tuer_Status'\nassignin('base','xSoll',xSo"
      "ll);                                     %schreibt die aktuelle Position in 'XSollwert'\nassignin('base','GUI_xI"
      "st',xIst);                                         %schreibt die aktuelle Position in 'X_aktuell'\nassignin('bas"
      "e','GUI_Anforderung',Anforderung);                                %schreibt die aktuelle Stockwerksanforderung i"
      "n 'Anforderung'\n\ny=0;                                                                        %Ausgang hiervon "
      "wird nicht benoetigt-> auf Terminator"
      editorLayout	      "100 M4x1[30 25 1296 912]"
    }
  }
